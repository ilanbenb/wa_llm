{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: ["config:recommended", "schedule:weekly"],

  // Keep PR titles/commits compatible with semantic PR title checks.
  semanticCommits: "enabled",
  semanticCommitType: "chore",
  semanticCommitScope: "deps",

  labels: ["dependencies"],
  prConcurrentLimit: 5,
  prHourlyLimit: 2,

  // uv projects: keep lockfile maintenance enabled for transitive updates.
  lockFileMaintenance: {
    enabled: true,
  },

  packageRules: [
    {
      description: "Update lower bounds in pyproject.toml (not lockfile-only).",
      matchManagers: ["pep621"],
      rangeStrategy: "bump",
    },
    {
      description: "Group non-major Python dependency updates.",
      matchManagers: ["pep621"],
      matchDatasources: ["pypi"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "python non-major dependencies",
    },
  ],
}
